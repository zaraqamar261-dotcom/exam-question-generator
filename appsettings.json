{
  "Gemini": {
    "ApiEndpoint": "https://generativelanguage.googleapis.com/",
    "Model": "gemini-pro",
    "MaxQuestionsPerRequest": 10,
    "DefaultDifficulty": "Medium"
  },
  "Storage": {
    "QuestionSetsDirectory": "QuestionSets",
    "MaxStoredSets": 100
  },
  "Application": {
    "Version": "1.0.0",
    "Name": "Exam Question Generator",
    "Description": "C# WinForms Exam Question Generator using Gemini API"
  }
}
